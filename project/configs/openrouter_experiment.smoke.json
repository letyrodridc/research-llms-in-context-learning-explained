{
  "schema_version": "openrouter_experiment_v1",
  "experiment_name": "smoke_pets_nle",
  "description": "Small smoke test to validate OpenRouter connectivity, prompts, and output layout.",
  "env_file": "../../.env",
  "output_root": "../openrouter_runs",
  "prompt_library_path": "openrouter_prompt_library.default.json",
  "model": {
    "name": "google/gemini-2.5-flash",
    "validate_image_input": true,
    "generation": {
      "temperature": 0.0
    }
  },
  "datasets": [
    "pets"
  ],
  "prompt_types": [
    "nle"
  ],
  "few_shot_configs": [
    {
      "n": 2,
      "k": 1,
      "q": 9
    }
  ],
  "runs_per_config": 1,
  "seed": 42,
  "analysis": {
    "enabled": true
  },
  "logging": {
    "write_full_conversations": true,
    "write_request_payloads": true,
    "write_sharded_logs": true
  }
}
