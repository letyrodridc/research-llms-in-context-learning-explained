{
  "schema_version": "openrouter_experiment_v1",
  "experiment_name": "full_default_openrouter_run",
  "description": "Full OpenRouter experiment over all datasets, prompt conditions, and few-shot settings.",
  "env_file": "../../.env",
  "output_root": "../openrouter_runs",
  "prompt_library_path": "openrouter_prompt_library.default.json",
  "model": {
    "name": "google/gemini-2.5-flash",
    "validate_image_input": true,
    "site_url": null,
    "app_name": null,
    "timeout_seconds": null,
    "max_retries": null,
    "generation": {
      "temperature": 0.0
    }
  },
  "datasets": [
    "flowers",
    "pets",
    "cifar10",
    "dtd"
  ],
  "prompt_types": [
    "classification",
    "nle",
    "features",
    "rulebased",
    "axioms_ontology_v2"
  ],
  "few_shot_configs": [
    {
      "n": 2,
      "k": 2,
      "q": 9
    },
    {
      "n": 2,
      "k": 1,
      "q": 9
    },
    {
      "n": 3,
      "k": 1,
      "q": 9
    },
    {
      "n": 4,
      "k": 1,
      "q": 9
    }
  ],
  "runs_per_config": 3,
  "seed": 42,
  "analysis": {
    "enabled": true
  },
  "logging": {
    "write_full_conversations": true,
    "write_request_payloads": true,
    "write_sharded_logs": true
  }
}
